#######################################################
# --- 3. Define workflown directory and Variables --- #
#######################################################
DATA = config["data_dir"]
OUT_DIR = config["output_dir"]

# Global Variables
SAMPLES, = glob_wildcards(DATA, "{sample}.fastq.gz")


###########################################
# --- 4. Import functions to be used --- #
##########################################
import os
import ast 
from glob import glob
from scripts.functions import get_final_outputs

############################################
# --- 5. Export functions to be used.  --- #
###########################################
import scripts.functions as functions
functions.DATA = DATA
