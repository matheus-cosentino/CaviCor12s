functions.MODULES = config["modules"]
functions.get_final_outputs = get_final_outputs


#######################################
# --- 6. Load the Workflow Rules --- #
######################################
include: "rules/blast.smk"


######################################
# --- 7. Obtain the final target --- #
######################################
rule all:
  input:
    get_final_outputs() 
  onsuccess:
    print("Workflow finished successfully!")
  onerror:
    print("Workflow failed. Temporary files were NOT removed to aid debugging.")